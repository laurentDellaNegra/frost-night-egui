---
const radii = [
  { name: 'sm', value: '4px' },
  { name: 'md', value: '6px' },
  { name: 'lg', value: '8px' },
];
---

<div class="radius-scale">
  {radii.map(r => (
    <div class="radius-item">
      <div class="radius-box" style={`border-radius: var(--radius-${r.name})`}></div>
      <div class="radius-info">
        <span class="radius-label">{r.name}</span>
        <code class="radius-value">{r.value}</code>
      </div>
    </div>
  ))}
</div>

<style>
  .radius-scale {
    display: flex;
    gap: var(--spacing-lg);
  }
  .radius-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
  }
  .radius-box {
    width: 80px;
    height: 80px;
    background: var(--accent);
    border: 2px solid var(--ring);
  }
  .radius-label {
    font-weight: 600;
    font-size: 0.875rem;
  }
  .radius-value {
    font-size: 0.75rem;
    color: var(--muted-foreground);
  }
</style>
