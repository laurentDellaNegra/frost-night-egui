---
interface Props {
  story: string;
  height?: string;
  title?: string;
}
const { story, height = '250px', title } = Astro.props;
const canvasId = `story-${story}-${Math.random().toString(36).slice(2, 8)}`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<span class="preview-hint">Rendered in WASM — scroll may behave differently from the rest of the page</span>
<div class="component-preview">
  {title && <span class="preview-label">{title}</span>}
  <div class="preview-canvas-wrapper" style={`height: ${height}`}>
    <canvas id={canvasId} class="story-canvas" data-story={story} data-base={base}></canvas>
  </div>
</div>

<style>
  .component-preview {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin: 1.5rem 0;
  }
  .preview-label {
    display: block;
    padding: var(--spacing-sm) var(--spacing-md);
    font-size: 0.8rem;
    color: var(--muted-foreground);
    border-bottom: 1px solid var(--border);
  }
  .preview-canvas-wrapper {
    position: relative;
    background: var(--background);
  }
  .story-canvas {
    width: 100% !important;
    height: 100% !important;
  }
  .preview-hint {
    display: block;
    margin-bottom: var(--spacing-xs);
    font-size: 0.7rem;
    font-style: italic;
    color: var(--muted-foreground);
    opacity: 0.7;
  }
</style>

<script is:inline>
  if (!window.__storyObserver) {
    window.__storyObserver = new IntersectionObserver((entries) => {
      entries.forEach(async (entry) => {
        if (!entry.isIntersecting) return;
        const canvas = entry.target;
        const story = canvas.dataset.story;
        const base = canvas.dataset.base;
        if (canvas.dataset.loaded) return;
        canvas.dataset.loaded = "true";

        try {
          const wasm = await import(base + '/wasm/ui-storybook.js');
          await wasm.default();
          wasm.start_story(canvas.id, story);
        } catch (e) {
          console.warn('Story WASM not available:', story, e.message);
        }

        window.__storyObserver.unobserve(canvas);
      });
    }, { threshold: 0.1 });
  }
  document.querySelectorAll('.story-canvas:not([data-observed])').forEach(c => {
    c.dataset.observed = "true";
    window.__storyObserver.observe(c);
  });
</script>
