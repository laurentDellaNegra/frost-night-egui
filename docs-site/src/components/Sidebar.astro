---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname;

const foundations = [
  { title: 'Colors', href: `${base}/foundations/colors` },
  { title: 'Typography', href: `${base}/foundations/typography` },
  { title: 'Spacing', href: `${base}/foundations/spacing` },
  { title: 'Radius', href: `${base}/foundations/radius` },
  { title: 'Blur / Surfaces', href: `${base}/foundations/blur` },
];

const components = [
  { title: 'Accordion', href: `${base}/components/accordion` },
  { title: 'Button', href: `${base}/components/button` },
  { title: 'Text Input', href: `${base}/components/input` },
  { title: 'Checkbox', href: `${base}/components/checkbox` },
  { title: 'Toggle', href: `${base}/components/toggle` },
  { title: 'Segmented', href: `${base}/components/segmented` },
  { title: 'Badge', href: `${base}/components/badge` },
  { title: 'Card', href: `${base}/components/card` },
  { title: 'Drag Card', href: `${base}/components/drag-card` },
  { title: 'Sidebar Card', href: `${base}/components/sidebar-card` },
  { title: 'Tabs', href: `${base}/components/tabs` },
  { title: 'Toolbar', href: `${base}/components/toolbar` },
  { title: 'Separator', href: `${base}/components/separator` },
];
---

<div class="mobile-bar">
  <a href={base} class="logo"><span class="logo-icon">❄</span> Frost Night UI</a>
  <button class="menu-toggle" aria-label="Toggle menu">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
      <path class="hamburger" d="M3 5h14M3 10h14M3 15h14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      <path class="close" d="M5 5l10 10M15 5l-10 10" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
  </button>
</div>

<nav class="sidebar" id="sidebar-nav">
  <div class="sidebar-header">
    <a href={base} class="logo"><span class="logo-icon">❄</span> Frost Night UI</a>
  </div>

  <a href={`${base}/demo-fullscreen`} class="demo-link">Live Demo</a>

  <div class="nav-section">
    <span class="nav-section-title">Foundations</span>
    <ul>
      {foundations.map(item => (
        <li>
          <a href={item.href} class:list={[{ active: currentPath.includes(item.href) }]}>
            {item.title}
          </a>
        </li>
      ))}
    </ul>
  </div>

  <div class="nav-section">
    <span class="nav-section-title">Components</span>
    <ul>
      {components.map(item => (
        <li>
          <a href={item.href} class:list={[{ active: currentPath.includes(item.href) }]}>
            {item.title}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .mobile-bar {
    display: none;
  }

  .sidebar {
    width: 240px;
    min-height: 100vh;
    border-right: 1px solid var(--border);
    padding: var(--spacing-lg);
    position: sticky;
    top: 0;
    overflow-y: auto;
    flex-shrink: 0;
  }

  .sidebar-header {
    margin-bottom: var(--spacing-xl);
  }

  .logo {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--foreground);
    text-decoration: none;
  }

  .logo-icon {
    font-size: 1.4rem;
  }

  .demo-link {
    display: block;
    padding: var(--spacing-sm) var(--spacing-md);
    background: var(--accent);
    border: 1px solid var(--ring);
    border-radius: var(--radius-md);
    color: var(--ring);
    font-weight: 600;
    text-align: center;
    margin-bottom: var(--spacing-xl);
    text-decoration: none;
    transition: background 0.15s;
  }

  .demo-link:hover {
    background: var(--control-fill-on);
    text-decoration: none;
  }

  .nav-section {
    margin-bottom: var(--spacing-lg);
  }

  .nav-section-title {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted-foreground);
    margin-bottom: var(--spacing-sm);
  }

  ul {
    list-style: none;
    padding: 0;
  }

  li a {
    display: block;
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    color: var(--muted-foreground);
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }

  li a:hover {
    color: var(--foreground);
    background: var(--muted);
    text-decoration: none;
  }

  li a.active {
    color: var(--ring);
    background: var(--accent);
  }

  .menu-toggle {
    background: none;
    border: none;
    color: var(--foreground);
    cursor: pointer;
    padding: var(--spacing-xs);
  }

  .close { display: none; color: white; }

  @media (max-width: 768px) {
    .mobile-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--spacing-sm) var(--spacing-lg);
      border-bottom: 1px solid var(--border);
      background: var(--background);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .sidebar {
      display: none;
      width: 100%;
      min-height: auto;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 99;
      border-right: none;
      background: var(--background);
      overflow-y: auto;
      padding-top: 60px;
    }

    .sidebar.open {
      display: block;
    }

    .sidebar .sidebar-header {
      display: none;
    }
  }
</style>

<script is:inline>
  (function() {
    const toggle = document.querySelector('.menu-toggle');
    const sidebar = document.getElementById('sidebar-nav');
    const hamburger = toggle.querySelector('.hamburger');
    const close = toggle.querySelector('.close');

    toggle.addEventListener('click', function() {
      const open = sidebar.classList.toggle('open');
      hamburger.style.display = open ? 'none' : 'inline';
      close.style.display = open ? 'inline' : 'none';
    });

    sidebar.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', function() {
        sidebar.classList.remove('open');
        hamburger.style.display = 'inline';
        close.style.display = 'none';
      });
    });
  })();
</script>
